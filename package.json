{
  "//": "@xterm/xterm: beta chosen because stable has broken horizontal + vertical scrolling",
  "name": "mywebterm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts --dev --port 18671",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"'",
    "start": "bun --no-env-file src/index.ts --port 8671",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --write src/",
    "tsc": "bunx tsc --noEmit",
    "htpasswd": "bun src/gen-htpasswd.ts"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.1.0-beta.167",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@types/bun": "^1.3.9",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
